# ── Core ─────────────────────────────────────────────────────────────────
# Copy to .env and fill in values

# JWT signing secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=changeme-use-a-strong-random-secret

# ── AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── DynamoDB ─────────────────────────────────────────────────────────────
DYNAMO_USERS_TABLE=axon-users
DYNAMO_AGENTS_TABLE=axon-agents
DYNAMO_MESSAGES_TABLE=axon-messages
# For local dev with DynamoDB Local:
# DYNAMO_ENDPOINT_URL=http://localhost:8001

# ── Docker ───────────────────────────────────────────────────────────────
AGENT_IMAGE=axon-agent-base:latest
AGENT_NETWORK=axon-agents
AGENT_MEM_LIMIT=256m
AGENT_CPU_QUOTA=50000

# ── Google OAuth ─────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback (dev)
#                           https://your-backend.onrender.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Where the backend sends the browser after OAuth completes
FRONTEND_URL=http://localhost:3000

# ── API ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
